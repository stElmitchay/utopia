# ============================================================================
# Utopia Environment Variables
# ============================================================================

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Privy (Wallet Authentication)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Monime (Credits System)
# Get these from: https://dashboard.monime.io → Developers
MONIME_SECRET_KEY=mon_test_xxxxxxxxxxxxx
MONIME_SPACE_ID=spc_xxxxxxxxxxxxx
MONIME_MAIN_FINANCIAL_ACCOUNT_ID=fa_xxxxxxxxxxxxx
MONIME_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Cron Secret (for scheduled balance syncs)
CRON_SECRET=generate-a-random-secret-here
